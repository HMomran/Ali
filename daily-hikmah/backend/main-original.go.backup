package main

import (
	"encoding/json"
	"fmt"
	"log"
	"net/http"
	"os"
	"sync"
	"time"

	webpush "github.com/SherClockHolmes/webpush-go"
)

// PushSubscription represents a browser push subscription
type PushSubscription struct {
	Endpoint string `json:"endpoint"`
	Keys     struct {
		P256dh string `json:"p256dh"`
		Auth   string `json:"auth"`
	} `json:"keys"`
}

// Notification payload sent to users
type Notification struct {
	Title   string `json:"title"`
	Message string `json:"message"`
}

// VAPIDKeys stores the public and private VAPID keys
type VAPIDKeys struct {
	PublicKey  string
	PrivateKey string
}

// SubscriptionStore manages all push subscriptions
type SubscriptionStore struct {
	mu            sync.RWMutex
	subscriptions []PushSubscription
}

func (s *SubscriptionStore) Add(sub PushSubscription) {
	s.mu.Lock()
	defer s.mu.Unlock()

	// Check if subscription already exists
	for _, existing := range s.subscriptions {
		if existing.Endpoint == sub.Endpoint {
			log.Printf("Subscription already exists: %s", sub.Endpoint[:50])
			return
		}
	}

	s.subscriptions = append(s.subscriptions, sub)
	log.Printf("New subscription added. Total subscribers: %d", len(s.subscriptions))
}

func (s *SubscriptionStore) GetAll() []PushSubscription {
	s.mu.RLock()
	defer s.mu.RUnlock()

	subs := make([]PushSubscription, len(s.subscriptions))
	copy(subs, s.subscriptions)
	return subs
}

func (s *SubscriptionStore) Remove(endpoint string) {
	s.mu.Lock()
	defer s.mu.Unlock()

	for i, sub := range s.subscriptions {
		if sub.Endpoint == endpoint {
			s.subscriptions = append(s.subscriptions[:i], s.subscriptions[i+1:]...)
			log.Printf("Subscription removed. Total subscribers: %d", len(s.subscriptions))
			return
		}
	}
}

func (s *SubscriptionStore) Count() int {
	s.mu.RLock()
	defer s.mu.RUnlock()
	return len(s.subscriptions)
}

var (
	vapidKeys     VAPIDKeys
	subStore      = &SubscriptionStore{}
	sayings       []string
	sayingCounter int
	counterMutex  sync.Mutex
	currentWisdom string
)

// generateVAPIDKeys creates VAPID keys using webpush library
func generateVAPIDKeys() (VAPIDKeys, error) {
	privateKey, publicKey, err := webpush.GenerateVAPIDKeys()
	if err != nil {
		return VAPIDKeys{}, err
	}

	return VAPIDKeys{
		PublicKey:  publicKey,
		PrivateKey: privateKey,
	}, nil
}

// loadOrGenerateVAPIDKeys loads existing keys or generates new ones
func loadOrGenerateVAPIDKeys() error {
	const keysFile = "vapid_keys.json"

	// Try to load existing keys
	data, err := os.ReadFile(keysFile)
	if err == nil {
		if err := json.Unmarshal(data, &vapidKeys); err == nil {
			log.Println("Loaded existing VAPID keys")
			return nil
		}
	}

	// Generate new keys
	log.Println("Generating new VAPID keys...")
	keys, err := generateVAPIDKeys()
	if err != nil {
		return fmt.Errorf("failed to generate VAPID keys: %v", err)
	}

	vapidKeys = keys

	// Save keys to file
	data, err = json.MarshalIndent(vapidKeys, "", "  ")
	if err != nil {
		return err
	}

	if err := os.WriteFile(keysFile, data, 0600); err != nil {
		return fmt.Errorf("failed to save VAPID keys: %v", err)
	}

	log.Println("VAPID keys generated and saved")
	return nil
}

// loadSayings loads Arabic wisdom from JSON file
func loadSayings(filename string) error {
	data, err := os.ReadFile(filename)
	if err != nil {
		return fmt.Errorf("failed to read %s: %v", filename, err)
	}

	if err := json.Unmarshal(data, &sayings); err != nil {
		return fmt.Errorf("failed to parse %s: %v", filename, err)
	}

	if len(sayings) == 0 {
		return fmt.Errorf("%s contains no sayings", filename)
	}

	log.Printf("Loaded %d sayings from %s", len(sayings), filename)
	return nil
}

// getTodaysSaying returns the current wisdom
// The wisdom is updated by the broadcast scheduler
func getTodaysSaying() string {
	counterMutex.Lock()
	defer counterMutex.Unlock()
	return currentWisdom
}

// updateWisdom rotates to the next wisdom saying
func updateWisdom() {
	counterMutex.Lock()
	defer counterMutex.Unlock()

	currentWisdom = sayings[sayingCounter%len(sayings)]
	sayingCounter++
	log.Printf("🔄 Wisdom updated (#%d): %s", sayingCounter, currentWisdom)
}

// sendPushNotification sends a Web Push notification to a subscriber
func sendPushNotification(sub PushSubscription, notif Notification) error {
	payload, err := json.Marshal(notif)
	if err != nil {
		return err
	}

	// Create subscription object for webpush library
	s := &webpush.Subscription{
		Endpoint: sub.Endpoint,
		Keys: webpush.Keys{
			Auth:   sub.Keys.Auth,
			P256dh: sub.Keys.P256dh,
		},
	}

	// Send push notification
	resp, err := webpush.SendNotification(payload, s, &webpush.Options{
		Subscriber:      "mailto:admin@example.com",
		VAPIDPublicKey:  vapidKeys.PublicKey,
		VAPIDPrivateKey: vapidKeys.PrivateKey,
		TTL:             30,
	})

	if err != nil {
		return fmt.Errorf("failed to send push: %v", err)
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusOK && resp.StatusCode != http.StatusCreated {
		return fmt.Errorf("push service responded with status: %d", resp.StatusCode)
	}

	log.Printf("📤 Push notification sent to: %s... (status: %d)",
		sub.Endpoint[:50], resp.StatusCode)

	return nil
}

// broadcastNotification sends notification to all subscribers
func broadcastNotification(notif Notification) {
	subscribers := subStore.GetAll()

	if len(subscribers) == 0 {
		log.Println("⚠️  No subscribers to notify")
		return
	}

	log.Printf("📢 Broadcasting to %d subscribers: %s", len(subscribers), notif.Message)

	// Send notifications concurrently
	var wg sync.WaitGroup
	for _, sub := range subscribers {
		wg.Add(1)
		go func(s PushSubscription) {
			defer wg.Done()
			if err := sendPushNotification(s, notif); err != nil {
				log.Printf("❌ Failed to send push to %s: %v", s.Endpoint[:50], err)
			}
		}(sub)
	}

	wg.Wait()
	log.Println("✅ Daily notification broadcast complete")
}

// dailyBroadcaster sends wisdom once per day
func dailyBroadcaster() {
	send := func() {
		// Update to next wisdom
		updateWisdom()

		notif := Notification{
			Title:   "حكمة اليوم",
			Message: getTodaysSaying(),
		}
		broadcastNotification(notif)
	}

	// Send immediately on startup
	send()

	// Then send every 5 hours
	ticker := time.NewTicker(5 * time.Hour)
	defer ticker.Stop()

	for range ticker.C {
		send()
	}
}

// Handler for POST /subscribe
func subscribeHandler(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodPost {
		http.Error(w, "Method not allowed", http.StatusMethodNotAllowed)
		return
	}

	var sub PushSubscription
	if err := json.NewDecoder(r.Body).Decode(&sub); err != nil {
		log.Printf("Invalid subscription data: %v", err)
		http.Error(w, "Invalid request body", http.StatusBadRequest)
		return
	}

	if sub.Endpoint == "" {
		http.Error(w, "Invalid subscription: missing endpoint", http.StatusBadRequest)
		return
	}

	subStore.Add(sub)

	// Send immediate welcome notification with today's wisdom
	go func() {
		notif := Notification{
			Title:   "حكمة اليوم",
			Message: getTodaysSaying(),
		}
		if err := sendPushNotification(sub, notif); err != nil {
			log.Printf("Failed to send welcome notification: %v", err)
		}
	}()

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{
		"success": true,
		"message": "Subscribed successfully",
	})
}

// Handler for GET /vapid-public-key
func vapidPublicKeyHandler(w http.ResponseWriter, r *http.Request) {
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]string{
		"publicKey": vapidKeys.PublicKey,
	})
}

// Handler for GET /today
func todayHandler(w http.ResponseWriter, r *http.Request) {
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(Notification{
		Title:   "حكمة اليوم",
		Message: getTodaysSaying(),
	})
}

func main() {
	// Load VAPID keys (or generate new ones)
	if err := loadOrGenerateVAPIDKeys(); err != nil {
		log.Fatalf("VAPID key error: %v", err)
	}

	// Load Arabic sayings
	if err := loadSayings("data/hikmah.json"); err != nil {
		log.Fatalf("Failed to load sayings: %v", err)
	}

	// Start daily broadcast goroutine
	go dailyBroadcaster()

	// Setup HTTP routes
	mux := http.NewServeMux()

	// API endpoints
	mux.HandleFunc("/subscribe", subscribeHandler)
	mux.HandleFunc("/vapid-public-key", vapidPublicKeyHandler)
	mux.HandleFunc("/today", todayHandler)

	// Serve static files
	mux.Handle("/", http.FileServer(http.Dir("./static")))

	// Start server
	server := &http.Server{
		Addr:    ":8080",
		Handler: mux,
	}

	log.Println("╔════════════════════════════════════════════════╗")
	log.Println("║   Daily Hikmah Server - حكمة اليوم           ║")
	log.Println("╚════════════════════════════════════════════════╝")
	log.Printf("Server: http://localhost:8080")
	log.Printf("Loaded sayings: %d", len(sayings))
	log.Printf("Current subscribers: %d", subStore.Count())
	log.Println("\n💡 Notifications sent every 5 hours")
	log.Println("⚠️  IMPORTANT: Clear browser cache or use Incognito mode!")
	log.Println("   Old VAPID keys may be cached by the browser.")
	log.Println("")
	log.Println("📱 Steps to test:")
	log.Println("   1. Open Chrome in Incognito mode")
	log.Println("   2. Go to http://localhost:8080")
	log.Println("   3. Subscribe to notifications")
	log.Println("   4. Wait 5 hours for the next notification")
	log.Println("")

	if err := server.ListenAndServe(); err != nil {
		log.Fatal(err)
	}
}
