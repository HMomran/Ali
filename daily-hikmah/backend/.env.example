# ====================================
# Daily Hikmah - Environment Variables
# ====================================

# VAPID Keys (Required for Push Notifications)
# Generate these keys by running the backend once locally
# or use: go run generate_vapid_keys.go

VAPID_PUBLIC_KEY=your_public_key_here
VAPID_PRIVATE_KEY=your_private_key_here

# Server Port (Optional - Render sets this automatically)
# For local development, use 8080
PORT=8080
